# ============================================
# Local development (docker-compose.yml)
# ============================================
DB_USERNAME=wikiaim
DB_PASSWORD=wikipass

# ============================================
# Deployment (docker-compose.deploy.yml)
# Create this file at /var/www/wikiaim/wikiaim-backend/<env>/.env
# ============================================
# ENV_NAME=prod                            # prod | preprod (Micronaut environment)
# IMAGE_TAG=prod                          # prod | preprod
# TRAEFIK_SERVICE_NAME=wikiaim-api-prod   # unique per env (Traefik router name)
# DB_USERNAME=wikiaim_prod
# DB_PASSWORD=<strong-password>
# JWT_SECRET=<strong-secret-min-32-chars>
# CORS_ORIGIN=https://wikiaim.fr
# WIKIAIM_DOMAIN=api.wikiaim.fr
#
# --- Basic Auth (preprod only, leave empty for prod) ---
# TRAEFIK_MIDDLEWARES=wikiaim-api-preprod-auth
# BASIC_AUTH_USERS=admin:$$apr1$$hashed_password
# Generate with: htpasswd -n admin
